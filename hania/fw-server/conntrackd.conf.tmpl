General {
    HashSize 32768
    HashLimit 131072
    LogFile on
    LockFile /var/lock/conntrack.lock
    UNIX {
        Path /var/run/conntrackd.ctl
        Backlog 20
    }
    NetlinkBufferSize 2097152
    NetlinkBufferSizeMaxGrowth 8388608
    Filter From Kernelspace {
        Protocol Accept {
            TCP
            UDP
            ICMP
        }
        Address Ignore {
            IPv4_address 127.0.0.1
        }
    }
}

Sync {
    Mode FTFW {
        DisableExternalCache Off
        CommitTimeout 1800
        PurgeTimeout 5
    }
    UDP {
        IPv4_address __LOCAL_SYNC_IP__
        IPv4_Destination_Address __PEER_SYNC_IP__
        Port 3780
        Interface __SYNC_IF__
        SndSocketBuffer 1249280
        RcvSocketBuffer 1249280
        Checksum on
    }
}